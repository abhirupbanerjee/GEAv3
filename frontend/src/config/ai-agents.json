{
  "$comment": "Registry of available AI agents. To add a new agent, append an entry below. NEVER put bearer tokens in this file. Tokens are read from the environment variable named in `tokenEnv` (server-side only).",
  "agents": [
    {
      "id": "policybot-testing",
      "name": "Policy Bot - Testing",
      "description": "General purpose testing agent. Accepts a query and returns an answer.",
      "endpoint": "https://policybot.abhirup.app/api/agent-bots/testing/invoke",
      "tokenEnv": "AI_AGENT_TOKEN_POLICYBOT_TESTING",
      "acceptsFile": false,
      "outputTypes": [
        "md",
        "json",
        "text"
      ],
      "defaultOutputType": "md",
      "async": true
    },
    {
      "id": "testing",
      "name": "testing",
      "description": "To test agent calling!",
      "endpoint": "https://policybot.abhirup.app/api/agent-bots/testing/invoke",
      "tokenEnv": "AI_AGENT_TOKEN_TESTING",
      "acceptsFile": false,
      "outputTypes": [
        "md",
        "text",
        "json",
        "pdf",
        "image"
      ],
      "defaultOutputType": "md",
      "async": true
    },
    {
      "id": "file-testing-agent",
      "name": "File-testing-agent",
      "description": "Tests the file uploads!",
      "endpoint": "https://policybot.abhirup.app/api/agent-bots/file-testing-agent/invoke",
      "tokenEnv": "AI_AGENT_TOKEN_FILE_TESTING_AGENT",
      "acceptsFile": true,
      "outputTypes": [
        "text",
        "json",
        "md",
        "pdf",
        "word",
        "image"
      ],
      "defaultOutputType": "md",
      "fileUpload": {
        "maxFiles": 5,
        "maxSizeMB": 10,
        "required": false,
        "allowedTypes": [
          "pdf",
          "word"
        ]
      },
      "async": true
    },
    {
      "id": "agentic-portal-testing",
      "name": "Agentic-portal-testing",
      "description": "",
      "endpoint": "https://policybot.abhirup.app/api/agent-bots/agentic-portal-testing/invoke",
      "tokenEnv": "AI_AGENT_TOKEN_AGENTIC_PORTAL_TESTING",
      "acceptsFile": true,
      "outputTypes": [
        "text",
        "json",
        "md",
        "pdf"
      ],
      "defaultOutputType": "pdf",
      "fileUpload": {
        "maxFiles": 5,
        "maxSizeMB": 10,
        "required": false,
        "allowedTypes": [
          "word"
        ]
      },
      "async": true
    }
  ]
}
